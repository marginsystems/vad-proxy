# ---------------------------------------------------------------------------
# vad-proxy configuration. Copy to .env and fill in. All values are optional;
# sensible defaults let the core VAD path run with no keys (mock STT/LLM).
# ---------------------------------------------------------------------------

# --- VAD / segmentation tuning -------------------------------------------
VAD_PROXY_SAMPLE_RATE=16000
VAD_PROXY_VAD_CONFIDENCE=0.5
# Lower = faster speech onset detection; 0.1 saves ~100ms vs 0.2 (slight false-trigger risk).
VAD_PROXY_VAD_START_SECS=0.1
VAD_PROXY_VAD_STOP_SECS=0.8
# Optional noise gate on normalized RMS (0-1). 0 disables (Silero-only).
VAD_PROXY_VAD_MIN_VOLUME=0.0
# Max seconds of a single utterance before forcing a flush to STT.
VAD_PROXY_MAX_UTTERANCE_SECS=30

# --- STT backend: mock | deepgram | openai -------------------------------
VAD_PROXY_STT_BACKEND=mock
DEEPGRAM_API_KEY=
VAD_PROXY_DEEPGRAM_MODEL=nova-2
OPENAI_API_KEY=
VAD_PROXY_OPENAI_STT_MODEL=whisper-1

# --- LLM smart-layer (DeepSeek, OpenAI-compatible) -----------------------
# Set enabled=false to skip; if no key is present it silently falls back to
# pass-through (raw transcript, acoustic endpointing only).
VAD_PROXY_LLM_ENABLED=true
DEEPSEEK_API_KEY=
VAD_PROXY_LLM_BASE_URL=https://api.deepseek.com/v1
VAD_PROXY_LLM_MODEL=deepseek-chat

# --- Output adapter: stdout | webhook | openai_chat ----------------------
VAD_PROXY_OUTPUT=stdout
# webhook
VAD_PROXY_WEBHOOK_URL=
# openai_chat (proxy final text to another OpenAI-compatible chat endpoint)
VAD_PROXY_OUTPUT_BASE_URL=https://api.deepseek.com/v1
VAD_PROXY_OUTPUT_API_KEY=
VAD_PROXY_OUTPUT_MODEL=deepseek-chat

# --- Server --------------------------------------------------------------
VAD_PROXY_HOST=0.0.0.0
VAD_PROXY_PORT=8080
# Live interim transcripts: smart RMS-dip chunking while speaking (no LLM on interim).
# INTERIM_SECS is the max slice cap; slices cut earlier on word-boundary dips.
# Final turn still runs the LLM once on joined chunk transcripts (no re-STT).
# Tune for your voice/mic: docs/TUNING.md and scripts/preview_interim_chunks.py
VAD_PROXY_INTERIM_ENABLED=false
VAD_PROXY_INTERIM_SECS=2.0
VAD_PROXY_INTERIM_MIN_SECS=0.5
VAD_PROXY_INTERIM_SMART=true
VAD_PROXY_INTERIM_DIP_RATIO=0.35
# Sustained RMS dip duration before cutting; 0.04 works better than 0.06 at 1s max.
VAD_PROXY_INTERIM_DIP_HOLD_SECS=0.04
# Browser app origins allowed to connect (comma-separated full URLs).
# localhost / 127.0.0.1 are always permitted for local dev.
VAD_PROXY_ALLOWED_ORIGINS=https://app.customdomain.com

# --- Logging -------------------------------------------------------------
VAD_PROXY_LOG_DIR=logs
VAD_PROXY_LOG_LEVEL=INFO

# --- Personalization (roadmap; logging only in v1) -----------------------
# When true, each utterance's PCM + transcript is logged to build a personal
# dataset for future adaptation. Off by default for privacy.
VAD_PROXY_LOG_UTTERANCES=false
VAD_PROXY_DATA_DIR=data
